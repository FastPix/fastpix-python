# Copy this file to ".env" (same folder) and fill in your credentials.
#
# The SDK reads Basic Auth creds from environment variables:
# - FASTPIX_USERNAME
# - FASTPIX_PASSWORD
FASTPIX_USERNAME=
FASTPIX_PASSWORD=

# Optional: override the default API base URL (defaults to https://api.fastpix.io/v1/)
# FASTPIX_SERVER_URL=https://api.fastpix.io/v1/

